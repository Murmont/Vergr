rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isModerator() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'moderator'];
    }

    function isSquadMember(squadId) {
      return isAuth() && exists(/databases/$(database)/documents/squads/$(squadId)/members/$(request.auth.uid));
    }

    function isSquadAdmin(squadId) {
      return isAuth() && get(/databases/$(database)/documents/squads/$(squadId)/members/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    function isSquadOwner(squadId) {
      return isAuth() && get(/databases/$(database)/documents/squads/$(squadId)/members/$(request.auth.uid)).data.role == 'owner';
    }

    function validString(field, maxLen) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= maxLen;
    }

    function isConversationParticipant(convoId) {
      return isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.participants;
    }

    // ═══════════════════════════════════════════
    // APP CONFIG (read-only for clients)
    // ═══════════════════════════════════════════

    match /app_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // USERS
    // ═══════════════════════════════════════════

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isModerator();
      allow delete: if isAdmin();

      // Private subcollection — only the user
      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Blocked users list
      match /blocked/{blockedId} {
        allow read, write: if isOwner(userId);
      }

      // User's game library / linked accounts
      match /game_accounts/{accountId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════
    // FOLLOWS
    // ═══════════════════════════════════════════

    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // ═══════════════════════════════════════════
    // POSTS
    // ═══════════════════════════════════════════

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.authorId == request.auth.uid
        && validString('content', 5000);
      allow update: if isOwner(resource.data.authorId) || isModerator();
      allow delete: if isOwner(resource.data.authorId) || isModerator();

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth()
          && request.resource.data.authorId == request.auth.uid
          && validString('content', 2000);
        allow update: if isOwner(resource.data.authorId) || isModerator();
        allow delete: if isOwner(resource.data.authorId) || isModerator();
      }

      // Likes subcollection (document ID = userId)
      match /likes/{userId} {
        allow read: if true;
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
        allow update: if false;
      }

      // Saves/bookmarks subcollection
      match /saves/{userId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }
// ═══════════════════════════════════════════
// POLLS
// ═══════════════════════════════════════════

match /polls/{pollId} {
  allow read: if true;
  allow create: if isAuth(); // Allow users to create polls if you have a "Create" screen

  // Votes subcollection
  match /votes/{userId} {
    allow read: if true;
    allow create: if isOwner(userId); // Only the user can cast their own vote
  }
}
    // ═══════════════════════════════════════════
    // STORIES
    // ═══════════════════════════════════════════

    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
      allow update: if isOwner(resource.data.authorId);
      allow delete: if isOwner(resource.data.authorId) || isModerator();

      match /viewers/{viewerId} {
        allow read: if isOwner(resource.parent.data.authorId);
        allow create: if isAuth() && request.auth.uid == viewerId;
      }
    }

    // ═══════════════════════════════════════════
    // SQUADS
    // ═══════════════════════════════════════════

    match /squads/{squadId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isSquadAdmin(squadId) || isModerator();
      allow delete: if isSquadOwner(squadId) || isAdmin();

      // Members subcollection (doc ID = userId)
      match /members/{memberId} {
        allow read: if true;
        allow create: if isAuth() && (
          request.auth.uid == memberId ||  // joining
          isSquadAdmin(squadId)            // admin adding
        );
        allow update: if isSquadAdmin(squadId);
        allow delete: if isOwner(memberId) || isSquadAdmin(squadId);
      }

      // Squad chat messages
      match /chat/{messageId} {
        allow read: if isSquadMember(squadId);
        allow create: if isSquadMember(squadId)
          && request.resource.data.authorId == request.auth.uid
          && validString('content', 2000);
        allow update: if isOwner(resource.data.authorId) || isSquadAdmin(squadId);
        allow delete: if isOwner(resource.data.authorId) || isSquadAdmin(squadId);
      }

      // Squad events
      match /events/{eventId} {
        allow read: if true;
        allow create: if isSquadAdmin(squadId);
        allow update: if isSquadAdmin(squadId);
        allow delete: if isSquadAdmin(squadId);

        match /rsvps/{userId} {
          allow read: if isSquadMember(squadId);
          allow write: if isOwner(userId) && isSquadMember(squadId);
        }
      }

      // Squad challenges
      match /challenges/{challengeId} {
        allow read: if isSquadMember(squadId);
        allow create: if isSquadAdmin(squadId);
        allow update: if isSquadAdmin(squadId);
        allow delete: if isSquadAdmin(squadId);

        match /entries/{entryId} {
          allow read: if isSquadMember(squadId);
          allow create: if isSquadMember(squadId) && request.resource.data.userId == request.auth.uid;
        }
      }

      // Squad media gallery
      match /media/{mediaId} {
        allow read: if isSquadMember(squadId);
        allow create: if isSquadMember(squadId) && request.resource.data.uploadedBy == request.auth.uid;
        allow delete: if isOwner(resource.data.uploadedBy) || isSquadAdmin(squadId);
      }

      // Join requests
      match /join_requests/{requestId} {
        allow read: if isSquadAdmin(squadId);
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow update: if isSquadAdmin(squadId);
        allow delete: if isSquadAdmin(squadId) || isOwner(resource.data.userId);
      }

      // Pinned messages
      match /pinned/{pinnedId} {
        allow read: if isSquadMember(squadId);
        allow write: if isSquadAdmin(squadId);
      }
    }

    // ═══════════════════════════════════════════
    // DIRECT MESSAGES / CONVERSATIONS
    // ═══════════════════════════════════════════

    match /conversations/{convoId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;
      allow update: if isConversationParticipant(convoId);
      allow delete: if false; // archive only, never delete

      match /messages/{messageId} {
        allow read: if isConversationParticipant(convoId);
        allow create: if isConversationParticipant(convoId)
          && request.resource.data.senderId == request.auth.uid;
        allow update: if isOwner(resource.data.senderId); // edit own messages
        allow delete: if isOwner(resource.data.senderId);
      }
    }

    // ═══════════════════════════════════════════
    // NOTIFICATIONS
    // ═══════════════════════════════════════════

    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid; // mark read
      allow delete: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if false; // only Cloud Functions create notifications
    }

    // ═══════════════════════════════════════════
    // SHOP / E-COMMERCE
    // ═══════════════════════════════════════════

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuth()
          && request.resource.data.authorId == request.auth.uid;
        allow update: if isOwner(resource.data.authorId);
        allow delete: if isOwner(resource.data.authorId) || isModerator();
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin(); // status updates only via admin/functions
      allow delete: if false;

      match /items/{itemId} {
        allow read: if isAuth() && (
          get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid || isAdmin()
        );
        allow write: if false; // set at order creation only
      }
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId);

      match /items/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /wishlists/{userId} {
      allow read: if true; // wishlists can be public
      allow write: if isOwner(userId);

      match /items/{itemId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════
    // WALLET / COIN ECONOMY
    // ═══════════════════════════════════════════

    match /wallets/{userId} {
      allow read: if isOwner(userId);
      allow create: if false; // created by Cloud Function on user signup
      allow update: if false; // ONLY Cloud Functions modify wallet balances
      allow delete: if false;
    }

    match /transactions/{txId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if false; // ONLY Cloud Functions create transactions
      allow update: if false;
      allow delete: if false;
    }

    match /coin_packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // TIPS
    // ═══════════════════════════════════════════

    match /tips/{tipId} {
      allow read: if isAuth() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
      allow create: if false; // Cloud Functions only (validates wallet balance)
      allow update: if false;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // CREATORS
    // ═══════════════════════════════════════════

    match /creators/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /analytics/{period} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Cloud Functions only
      }

      match /payouts/{payoutId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Cloud Functions / Stripe webhooks only
      }
    }

    // ═══════════════════════════════════════════
    // MEMBERSHIPS (Creator subscription tiers)
    // ═══════════════════════════════════════════

    match /memberships/{membershipId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuth() && resource.data.creatorId == request.auth.uid;
      allow delete: if isAuth() && resource.data.creatorId == request.auth.uid;
    }

    match /member_subscriptions/{subId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        resource.data.creatorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if false; // Cloud Functions (payment required)
      allow update: if false;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // STREAMS
    // ═══════════════════════════════════════════

    match /streams/{streamId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.streamerId == request.auth.uid;
      allow update: if isOwner(resource.data.streamerId) || isModerator();
      allow delete: if isOwner(resource.data.streamerId) || isModerator();

      match /chat/{messageId} {
        allow read: if true;
        allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isOwner(resource.data.authorId) || isModerator();
      }

      match /drops/{dropId} {
        allow read: if true;
        allow write: if isOwner(resource.data.streamerId);
      }
    }

    // ═══════════════════════════════════════════
    // TOURNAMENTS / ESPORTS
    // ═══════════════════════════════════════════

    match /tournaments/{tourneyId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.organizerId == request.auth.uid || isAdmin();
      allow delete: if isAdmin();

      match /entries/{entryId} {
        allow read: if true;
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow update: if isAuth() && (
          resource.data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/tournaments/$(tourneyId)).data.organizerId == request.auth.uid
        );
        allow delete: if isAuth() && resource.data.userId == request.auth.uid;
      }

      match /brackets/{bracketId} {
        allow read: if true;
        allow write: if isAuth() && (
          get(/databases/$(database)/documents/tournaments/$(tourneyId)).data.organizerId == request.auth.uid || isAdmin()
        );
      }
    }

    // ═══════════════════════════════════════════
    // REPORTS / MODERATION
    // ═══════════════════════════════════════════

    match /reports/{reportId} {
      allow create: if isAuth() && request.resource.data.reporterId == request.auth.uid;
      allow read: if isModerator();
      allow update: if isModerator();
      allow delete: if isAdmin();
    }

    match /mod_actions/{actionId} {
      allow read: if isModerator();
      allow create: if isModerator();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /banned_words/{docId} {
      allow read: if isModerator();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // ADS
    // ═══════════════════════════════════════════

    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();

      match /impressions/{impId} {
        allow read: if isAdmin();
        allow create: if isAuth();
      }

      match /clicks/{clickId} {
        allow read: if isAdmin();
        allow create: if isAuth();
      }
    }

    // ═══════════════════════════════════════════
    // NEWS / GAMING NEWS
    // ═══════════════════════════════════════════

    match /news/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // HASHTAGS / TRENDING
    // ═══════════════════════════════════════════

    match /hashtags/{tag} {
      allow read: if true;
      allow write: if false; // Cloud Functions only
    }

    match /trending/{period} {
      allow read: if true;
      allow write: if false; // Cloud Functions only
    }

    // ═══════════════════════════════════════════
    // LEADERBOARDS
    // ═══════════════════════════════════════════

    match /leaderboards/{boardId} {
      allow read: if true;
      allow write: if false; // Cloud Functions only

      match /entries/{entryId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ═══════════════════════════════════════════
    // FEEDBACK / SUPPORT
    // ═══════════════════════════════════════════

    match /feedback/{feedbackId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
